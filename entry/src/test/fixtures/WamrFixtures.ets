// Spec test mini modules (hand-crafted from WAMR spec test patterns)
// ============================================================================

/** i64.div_u: 100 / 3 = 33 */
export const I64_DIV_U = makeSimpleI64Module([0x20, 0x00, 0x20, 0x01, 0x80]); // i64.div_u

/** i32.wrap_i64: wraps i64 to i32 */
export const I32_WRAP_I64 = makeModuleI64ToI32([0x20, 0x00, 0xa7]); // i32.wrap/i64

/** i32.reinterpret_f32: reinterpret f32 bits as i32 */
export const I32_REINTERPRET_F32 = makeModuleF32ToI32([0x20, 0x00, 0xbc]);

/** f32.reinterpret_i32: reinterpret i32 bits as f32 */
export const F32_REINTERPRET_I32 = makeModuleI32ToF32([0x20, 0x00, 0xbe]);

// ============================================================================
// Helper functions for building custom test modules
// ============================================================================

function makeSimpleI64Module(body: number[]): Uint8Array {
  const b: number[] = [];
  b.push(0x00, 0x61, 0x73, 0x6d, 0x01, 0x00, 0x00, 0x00);
  // type: (i64, i64) -> i64
  const tb = [0x01, 0x60, 0x02, 0x7e, 0x7e, 0x01, 0x7e];
  b.push(0x01); pushLeb(b, tb.length); b.push(...tb);
  b.push(0x03, 0x02, 0x01, 0x00);
  const nm = [0x04, 0x74, 0x65, 0x73, 0x74];
  const es = [0x01, ...nm, 0x00, 0x00];
  b.push(0x07); pushLeb(b, es.length); b.push(...es);
  const cb = [0x00, ...body, 0x0B];
  const cs = [0x01]; pushLeb(cs, cb.length); cs.push(...cb);
  b.push(0x0a); pushLeb(b, cs.length); b.push(...cs);
  return new Uint8Array(b);
}

function makeModuleI64ToI32(body: number[]): Uint8Array {
  const b: number[] = [];
  b.push(0x00, 0x61, 0x73, 0x6d, 0x01, 0x00, 0x00, 0x00);
  const tb = [0x01, 0x60, 0x01, 0x7e, 0x01, 0x7f];
  b.push(0x01); pushLeb(b, tb.length); b.push(...tb);
  b.push(0x03, 0x02, 0x01, 0x00);
  const nm = [0x04, 0x74, 0x65, 0x73, 0x74];
  b.push(0x07); pushLeb(b, 2 + nm.length); b.push(0x01, ...nm, 0x00, 0x00);
  const cb = [0x00, ...body, 0x0B];
  const cs = [0x01]; pushLeb(cs, cb.length); cs.push(...cb);
  b.push(0x0a); pushLeb(b, cs.length); b.push(...cs);
  return new Uint8Array(b);
}

function makeModuleF32ToI32(body: number[]): Uint8Array {
  const b: number[] = [];
  b.push(0x00, 0x61, 0x73, 0x6d, 0x01, 0x00, 0x00, 0x00);
  const tb = [0x01, 0x60, 0x01, 0x7d, 0x01, 0x7f];
  b.push(0x01); pushLeb(b, tb.length); b.push(...tb);
  b.push(0x03, 0x02, 0x01, 0x00);
  const nm = [0x04, 0x74, 0x65, 0x73, 0x74];
  b.push(0x07); pushLeb(b, 2 + nm.length); b.push(0x01, ...nm, 0x00, 0x00);
  const cb = [0x00, ...body, 0x0B];
  const cs = [0x01]; pushLeb(cs, cb.length); cs.push(...cb);
  b.push(0x0a); pushLeb(b, cs.length); b.push(...cs);
  return new Uint8Array(b);
}

function makeModuleI32ToF32(body: number[]): Uint8Array {
  const b: number[] = [];
  b.push(0x00, 0x61, 0x73, 0x6d, 0x01, 0x00, 0x00, 0x00);
  const tb = [0x01, 0x60, 0x01, 0x7f, 0x01, 0x7d];
  b.push(0x01); pushLeb(b, tb.length); b.push(...tb);
  b.push(0x03, 0x02, 0x01, 0x00);
  const nm = [0x04, 0x74, 0x65, 0x73, 0x74];
  b.push(0x07); pushLeb(b, 2 + nm.length); b.push(0x01, ...nm, 0x00, 0x00);
  const cb = [0x00, ...body, 0x0B];
  const cs = [0x01]; pushLeb(cs, cb.length); cs.push(...cb);
  b.push(0x0a); pushLeb(b, cs.length); b.push(...cs);
  return new Uint8Array(b);
}

function pushLeb(buf: number[], v: number): void {
  while (v >= 0x80) { buf.push((v & 0x7f) | 0x80); v >>>= 7; }
  buf.push(v & 0x7f);
}
