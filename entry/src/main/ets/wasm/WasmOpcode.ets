/**
 * Build a lookup map: opcode -> OpcodeInfo for fast dispatch reference
 */
export function buildOpcodeMap(): Map<number, OpcodeInfo> {
  const map = new Map<number, OpcodeInfo>();
  for (const info of OPCODE_TABLE) {
    map.set(info.op, info);
  }
  return map;
}

export const OPCODE_MAP: Map<number, OpcodeInfo> = buildOpcodeMap();

/**
 * Categorize opcodes by category
 */
export function groupOpcodesByCategory(): Map<OpcodeCategory, OpcodeInfo[]> {
  const groups = new Map<OpcodeCategory, OpcodeInfo[]>();
  for (const info of OPCODE_TABLE) {
    const cat = info.category;
    if (!groups.has(cat)) {
      groups.set(cat, []);
    }
    groups.get(cat)!.push(info);
  }
  return groups;
}

/**
 * Check if an opcode is a multi-byte prefix (starts a 2+ byte instruction)
 */
export function isPrefixOpcode(op: number): boolean {
  return op === WasmOp.GC_PREFIX || op === WasmOp.MISC_PREFIX ||
    op === WasmOp.SIMD_PREFIX || op === WasmOp.ATOMIC_PREFIX;
}
