// ============================================================================
// Opcode Metadata — for VMP (Virtual Machine Protection) development
// ============================================================================

export enum OpcodeCategory {
  CONTROL = 'control',
  PARAMETRIC = 'parametric',
  VARIABLE = 'variable',
  MEMORY = 'memory',
  CONSTANT = 'constant',
  I32_COMPARE = 'i32_compare',
  I64_COMPARE = 'i64_compare',
  F32_COMPARE = 'f32_compare',
  F64_COMPARE = 'f64_compare',
  I32_NUMERIC = 'i32_numeric',
  I64_NUMERIC = 'i64_numeric',
  F32_NUMERIC = 'f32_numeric',
  F64_NUMERIC = 'f64_numeric',
  CONVERSION = 'conversion',
  REINTERPRET = 'reinterpret',
  SIGN_EXTEND = 'sign_extend',
  REFERENCE = 'reference',
  GC_EXT = 'gc_ext',
  MISC_EXT = 'misc_ext',
  SIMD_EXT = 'simd_ext',
  ATOMIC_EXT = 'atomic_ext',
  INTERNAL = 'internal',
  PREFIX = 'prefix',
}

export interface OpcodeInfo {
  op: number;             // primary opcode byte
  prefix: number;         // 0 for single-byte, else prefix byte
  name: string;           // canonical name e.g. "i32.add"
  category: OpcodeCategory;
  stackIn: number;        // number of values consumed from stack
  stackOut: number;       // number of values produced on stack
  hasImmediate: boolean;  // whether immediate operands follow
}

