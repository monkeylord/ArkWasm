t('atomic.rmw i32 add',()=>{const b=[];b.push(0x00,0x61,0x73,0x6d,0x01,0x00,0x00,0x00);const tb=[0x01,0x60];pushLeb(tb,2);tb.push(0x7f,0x7f);pushLeb(tb,0);b.push(0x01);pushLeb(b,tb.length);b.push(...tb);b.push(0x03,0x02,0x01,0x00);b.push(0x05,0x03,0x01,0x00,0x01);const nm=[0x04,0x74,0x65,0x73,0x74];b.push(0x07);pushLeb(b,3+nm.length);b.push(0x01,...nm,0x00,0x00);const cb=[0x00,0x20,0x00,0x20,0x01,0xfe,0x1e,0x02,0x00,0x1a,0x0b];const cs=[0x01];pushLeb(cs,cb.length);cs.push(...cb);b.push(0x0a);pushLeb(b,cs.length);b.push(...cs);const rt=new WasmRuntime();const inst=rt.instantiate(new Uint8Array(b));const dv=new DataView(inst.memories[0].buffer);dv.setInt32(0,10,true);rt.invokeByName(inst,'test',[WasmValue.i32(0),WasmValue.i32(5)]);assertEq(dv.getInt32(0,true),15)});
t('atomic.fence nop',()=>{const b=[];b.push(0x00,0x61,0x73,0x6d,0x01,0x00,0x00,0x00);const tb=[0x01,0x60];pushLeb(tb,0);pushLeb(tb,1);tb.push(0x7f);b.push(0x01);pushLeb(b,tb.length);b.push(...tb);b.push(0x03,0x02,0x01,0x00);b.push(0x05,0x03,0x01,0x00,0x01);const nm=[0x04,0x74,0x65,0x73,0x74];b.push(0x07);pushLeb(b,3+nm.length);b.push(0x01,...nm,0x00,0x00);const cb=[0x00,0xfe,0x03,0x00,0x41,0x2a,0x0b];const cs=[0x01];pushLeb(cs,cb.length);cs.push(...cb);b.push(0x0a);pushLeb(b,cs.length);b.push(...cs);const r=new WasmRuntime().invokeByName(new WasmRuntime().instantiate(new Uint8Array(b)),'test',[]);if(r.trap)throw Error('trap: '+r.trap);assertEq(r.values[0].getAsI32(),42)});
