function makeMem64Module(body,initPages,maxPages){const b=[];b.push(0x00,0x61,0x73,0x6d,0x01,0x00,0x00,0x00);const tb=[0x01,0x60];pushLeb(tb,2);tb.push(0x7f,0x7f);pushLeb(tb,1);tb.push(0x7f);b.push(0x01);pushLeb(b,tb.length);b.push(...tb);b.push(0x03,0x02,0x01,0x00);const flags=maxPages!==undefined?0x05:0x04;const memB=[0x01,flags];pushLeb(memB,initPages);if(maxPages!==undefined)pushLeb(memB,maxPages);b.push(0x05);pushLeb(b,memB.length);b.push(...memB);const nm=[0x04,0x74,0x65,0x73,0x74];b.push(0x07);pushLeb(b,3+nm.length);b.push(0x01,...nm,0x00,0x00);const cb=[0x00,...body,0x0b];const cs=[0x01];pushLeb(cs,cb.length);cs.push(...cb);b.push(0x0a);pushLeb(b,cs.length);b.push(...cs);return new Uint8Array(b)}
