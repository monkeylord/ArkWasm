<!DOCTYPE html>
<html><head><meta charset="utf-8"><title>ArkWASM Test Suite</title>
<style>
body{font-family:Consolas,monospace;background:#1e1e1e;color:#d4d4d4;margin:20px;font-size:14px}
h1{color:#569cd6;margin:0 0 5px 0}.pass{color:#6a9955}.fail{color:#f44747}
.summary{font-size:18px;margin:10px 0;padding:10px;background:#252526;border-radius:5px}
.suite-head{color:#c586c0;font-size:15px;margin:8px 0 4px 0;font-weight:bold}
.test-pass{margin:1px 0 1px 20px}.test-fail{margin:1px 0 1px 20px}
.stats{font-size:16px;margin:10px 0;color:#4ec9b0}
.error-detail{color:#f44747;margin-left:20px;white-space:pre-wrap}
</style></head><body>
<h1>ArkWASM Test Suite</h1>
<div class="stats" id="stats">Loading...</div>
<div id="results"></div>

<!--RUNTIME-->

<script>
const $=id=>document.getElementById(id);
let total=0,passed=0,failed=0;
function testSuite(n){$('results').innerHTML+=`<div class="suite-head">${n}</div>`}
function t(n,fn){total++;try{fn();passed++;$('results').innerHTML+=`<div class="test-pass pass">  PASS: ${n}</div>`}catch(e){failed++;$('results').innerHTML+=`<div class="test-fail fail">  FAIL: ${n} — ${e.message}</div>`}}
function assertEq(a,b){if(a!==b)throw Error(typeof a==='bigint'||typeof b==='bigint'?`expected ${b} but got ${a}`:`expected ${b} but got ${a}`)}
function assertClose(a,b,eps){if(Math.abs(a-b)>(eps||0.0001))throw Error(`expected ~${b} but got ${a}`)}
function assertNotNull(v){if(v===null||v===undefined)throw Error('expected non-null')}
function assertThrows(fn){try{fn();throw Error('expected exception')}catch(e){if(e.message==='expected exception')throw e}}

function pushLeb(buf,v){while(v>=0x80){buf.push((v&0x7f)|0x80);v>>>=7}buf.push(v&0x7f)}
function makeModule(body,p,r){p=p||[];r=r||[0x7f];const b=[];b.push(0x00,0x61,0x73,0x6d,0x01,0x00,0x00,0x00);const tb=[0x01,0x60];pushLeb(tb,p.length);tb.push(...p);pushLeb(tb,r.length);tb.push(...r);b.push(0x01);pushLeb(b,tb.length);b.push(...tb);b.push(0x03,0x02,0x01,0x00);const nm=[0x04,0x74,0x65,0x73,0x74];b.push(0x07);pushLeb(b,3+nm.length);b.push(0x01,...nm,0x00,0x00);const cb=[0x00,...body,0x0b];const cs=[0x01];pushLeb(cs,cb.length);cs.push(...cb);b.push(0x0a);pushLeb(b,cs.length);b.push(...cs);return new Uint8Array(b)}
function makeMemModule(body){const b=[];b.push(0x00,0x61,0x73,0x6d,0x01,0x00,0x00,0x00);const tb=[0x01,0x60];pushLeb(tb,2);tb.push(0x7f,0x7f);pushLeb(tb,0);b.push(0x01);pushLeb(b,tb.length);b.push(...tb);b.push(0x03,0x02,0x01,0x00);b.push(0x05,0x03,0x01,0x00,0x01);const nm=[0x04,0x74,0x65,0x73,0x74];b.push(0x07);pushLeb(b,3+nm.length);b.push(0x01,...nm,0x00,0x00);const cb=[0x00,...body,0x0b];const cs=[0x01];pushLeb(cs,cb.length);cs.push(...cb);b.push(0x0a);pushLeb(b,cs.length);b.push(...cs);return new Uint8Array(b)}
function makeI64Bin(body){return makeModule(body,[0x7e,0x7e],[0x7e])}
function makeI64Unary(body){return makeModule(body,[0x7e],[0x7f])}
function makeF32Bin(body){return makeModule(body,[0x7d,0x7d],[0x7d])}
function makeF32Unary(body){return makeModule(body,[0x7d],[0x7d])}
function makeF32ToI32(body){return makeModule(body,[0x7d],[0x7f])}
function makeI32ToF32(body){return makeModule(body,[0x7f],[0x7d])}
function makeI32ToF64(body){return makeModule(body,[0x7f],[0x7c])}
function makeI32ToI64(body){return makeModule(body,[0x7f],[0x7e])}
function makeI64ToI32(body){return makeModule(body,[0x7e],[0x7f])}

function invoke(wasm,args){const rt=new WasmRuntime();const wa=(args||[]).map(a=>WasmValue.i32(a));const r=rt.invokeByName(rt.instantiate(wasm),'test',wa);if(r.trap)throw Error('trap: '+r.trap);return r.values[0]?r.values[0].getAsI32():0}
function invokeI64(wasm,args){const rt=new WasmRuntime();const wa=(args||[]).map(a=>{const w=WasmValue.i64(typeof a==='bigint'?a:BigInt(a|0));if(typeof a==='number')w.i32Val=a|0;return w});const r=rt.invokeByName(rt.instantiate(wasm),'test',wa);if(r.trap)throw Error('trap: '+r.trap);return r.values[0]?r.values[0].getAsI64():0n}
function invokeI32_f64(wasm,args){const rt=new WasmRuntime();const wa=args.map(a=>{const w=typeof a==='bigint'?WasmValue.i64(a):(()=>{const wv=WasmValue.i64(BigInt(a));wv.i32Val=a|0;return wv})();return w});const r=rt.invokeByName(rt.instantiate(wasm),'test',wa);if(r.trap)throw Error('trap: '+r.trap);return r.values[0].getAsI32()}
function invokeF32(wasm,args){const rt=new WasmRuntime();const wa=(args||[]).map(a=>{const w=WasmValue.f32(a);w.i32Val=a|0;return w});const r=rt.invokeByName(rt.instantiate(wasm),'test',wa);if(r.trap)throw Error('trap: '+r.trap);return r.values[0]?r.values[0].getAsF32():0}
function invokeF64(wasm,args){const rt=new WasmRuntime();const r=rt.invokeByName(rt.instantiate(wasm),'test',(args||[]).map(a=>WasmValue.f64(a)));if(r.trap)throw Error('trap: '+r.trap);return r.values[0]?r.values[0].getAsF64():0}
function invokeI32_fromF32(wasm,args){const rt=new WasmRuntime();const r=rt.invokeByName(rt.instantiate(wasm),'test',(args||[]).map(a=>WasmValue.f32(a)));if(r.trap)throw Error('trap: '+r.trap);return r.values[0]?r.values[0].getAsI32():0}

let body=[0x20,0x00,0x20,0x01,0x6a]
testSuite('Leb128');
t('readU32: zero',()=>{const d=new Uint8Array([0x00]);let pv=0;assertEq(Leb128.readU32(d,{v:pv}),0)});
t('readU32: 127',()=>{assertEq(Leb128.readU32(new Uint8Array([0x7f]),{v:0}),127)});
t('readU32: 128',()=>{assertEq(Leb128.readU32(new Uint8Array([0x80,0x01]),{v:0}),128)});
t('readU32: max',()=>{assertEq(Leb128.readU32(new Uint8Array([0xff,0xff,0xff,0xff,0x0f]),{v:0}),0xFFFFFFFF)});
t('readI32: 0',()=>{assertEq(Leb128.readI32(new Uint8Array([0x00]),{v:0}),0)});
t('readI32: -1',()=>{assertEq(Leb128.readI32(new Uint8Array([0x7f]),{v:0}),-1)});
t('readI64: 0n',()=>{assertEq(Leb128.readI64(new Uint8Array([0x00]),{v:0}),0n)});
t('readI64: -1n',()=>{assertEq(Leb128.readI64(new Uint8Array([0x7f]),{v:0}),-1n)});

testSuite('WasmLoader');
const EMPTY=new Uint8Array([0x00,0x61,0x73,0x6d,0x01,0x00,0x00,0x00,0x01,0x04,0x01,0x60,0x00,0x00,0x03,0x02,0x01,0x00,0x0a,0x04,0x01,0x02,0x00,0x0b]);
const EXP=new Uint8Array([0x00,0x61,0x73,0x6d,0x01,0x00,0x00,0x00,0x01,0x05,0x01,0x60,0x00,0x01,0x7f,0x03,0x02,0x01,0x00,0x07,0x09,0x01,0x05,0x68,0x65,0x6c,0x6c,0x6f,0x00,0x00,0x0a,0x06,0x01,0x04,0x00,0x41,0x2a,0x0b]);
t('loads empty',()=>{const m=new WasmLoader().load(EMPTY);assertEq(m.types.length,1);assertEq(m.funcDescs.length,1)});
t('rejects bad magic',()=>{assertThrows(()=>new WasmLoader().load(new Uint8Array([0x00,0x61,0x73,0x6e,0x01,0x00,0x00,0x00])))});
t('parses export',()=>{assertEq(new WasmLoader().load(EXP).exports[0].name,'hello')});
t('parses code',()=>{assertEq(new WasmLoader().load(EXP).funcDescs[0].code[0],0x41)});

testSuite('Constants');
t('i32.const 42',()=>{assertEq(invoke(makeModule([0x41,0x2a]),[]),42)});
t('f32.const 1.0',()=>{assertClose(invokeF32(makeModule([0x43,0x00,0x00,0x80,0x3f]),[]),1.0)});
t('f64.const -1.0',()=>{assertEq(invokeF64(makeModule([0x44,0x00,0x00,0x00,0x00,0x00,0x00,0xf0,0xbf]),[]),-1.0)});

testSuite('I32 Arithmetic');
t('add 3+4=7',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x6a],[0x7f,0x7f]),[3,4]),7)});
t('add overflow',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x6a],[0x7f,0x7f]),[0x7FFFFFFF,1]),-0x80000000)});
t('sub 10-3=7',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x6b],[0x7f,0x7f]),[10,3]),7)});
t('mul 3*4=12',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x6c],[0x7f,0x7f]),[3,4]),12)});
t('div_s 10/3=3',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x6d],[0x7f,0x7f]),[10,3]),3)});
t('div_u -1/2',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x6e],[0x7f,0x7f]),[-1,2]),2147483647)});
t('rem_s 10%3=1',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x6f],[0x7f,0x7f]),[10,3]),1)});
t('and 0xFF&0x0F',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x71],[0x7f,0x7f]),[0xFF,0x0F]),0x0F)});
t('or 0xF0|0x0F',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x72],[0x7f,0x7f]),[0xF0,0x0F]),0xFF)});
t('shl 1<<3=8',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x74],[0x7f,0x7f]),[1,3]),8)});
t('shr_s -4>>1=-2',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x75],[0x7f,0x7f]),[-4,1]),-2)});
t('shr_u -1>>1',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x76],[0x7f,0x7f]),[-1,1]),0x7FFFFFFF)});
t('rotl 1<<<1=2',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x77],[0x7f,0x7f]),[1,1]),2)});
t('rotr 1>>>1',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x78],[0x7f,0x7f]),[1,1]),-0x80000000)});
t('clz(0)=32',()=>{assertEq(invoke(makeModule([0x20,0x00,0x67],[0x7f]),[0]),32)});
t('ctz(8)=3',()=>{assertEq(invoke(makeModule([0x20,0x00,0x68],[0x7f]),[8]),3)});
t('popcnt(-1)=32',()=>{assertEq(invoke(makeModule([0x20,0x00,0x69],[0x7f]),[-1]),32)});

testSuite('I32 Comparisons');
t('eqz(0)=1',()=>{assertEq(invoke(makeModule([0x20,0x00,0x45],[0x7f]),[0]),1)});
t('eq 3==3',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x46],[0x7f,0x7f]),[3,3]),1)});
t('ne 3!=4',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x47],[0x7f,0x7f]),[3,4]),1)});
t('lt_s -2<-1',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x48],[0x7f,0x7f]),[-2,-1]),1)});
t('lt_u -1<1=0',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x49],[0x7f,0x7f]),[-1,1]),0)});
t('gt_s 5>3',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x4a],[0x7f,0x7f]),[5,3]),1)});
t('le_s 3<=3',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x4c],[0x7f,0x7f]),[3,3]),1)});
t('ge_s 2>=5=0',()=>{assertEq(invoke(makeModule([0x20,0x00,0x20,0x01,0x4e],[0x7f,0x7f]),[2,5]),0)});

testSuite('I64 Arithmetic');
t('add 3+4=7',()=>{assertEq(invokeI64(makeI64Bin([0x20,0x00,0x20,0x01,0x7c]),[3n,4n]),7n)});
t('sub 10-3=7',()=>{assertEq(invokeI64(makeI64Bin([0x20,0x00,0x20,0x01,0x7d]),[10n,3n]),7n)});
t('mul 3*4=12',()=>{assertEq(invokeI64(makeI64Bin([0x20,0x00,0x20,0x01,0x7e]),[3n,4n]),12n)});
t('and 0xFF&0x0F',()=>{assertEq(invokeI64(makeI64Bin([0x20,0x00,0x20,0x01,0x83]),[0xFFn,0x0Fn]),0x0Fn)});
t('shl 1<<8=256',()=>{assertEq(invokeI64(makeI64Bin([0x20,0x00,0x20,0x01,0x86]),[1n,8n]),256n)});

testSuite('Floating Point');
t('f32.add 1.5+2.5=4.0',()=>{assertClose(invokeF32(makeF32Bin([0x20,0x00,0x20,0x01,0x92]),[1.5,2.5]),4.0)});
t('f32.abs -5=5',()=>{assertClose(invokeF32(makeF32Unary([0x20,0x00,0x8b]),[-5]),5)});
t('f32.neg 3=-3',()=>{assertClose(invokeF32(makeF32Unary([0x20,0x00,0x8c]),[3]),-3)});
t('f32.ceil 1.3=2',()=>{assertClose(invokeF32(makeF32Unary([0x20,0x00,0x8d]),[1.3]),2)});
t('f32.floor 1.7=1',()=>{assertClose(invokeF32(makeF32Unary([0x20,0x00,0x8e]),[1.7]),1)});
t('f32.sqrt 4=2',()=>{assertClose(invokeF32(makeF32Unary([0x20,0x00,0x91]),[4]),2)});
t('f64.add PI+E',()=>{assertEq(invokeF64(makeModule([0x20,0x00,0x20,0x01,0xa0],[0x7c,0x7c],[0x7c]),[Math.PI,Math.E]),Math.PI+Math.E)});

testSuite('Sign Extension');
t('i32.extend8_s(0xFF)=-1',()=>{assertEq(invoke(makeModule([0x20,0x00,0xc0],[0x7f]),[0xFF]),-1)});
t('i32.extend16_s(0xFFFF)=-1',()=>{assertEq(invoke(makeModule([0x20,0x00,0xc1],[0x7f]),[0xFFFF]),-1)});

testSuite('Conversions');
t('i64.extend_s_i32(-1)',()=>{assertEq(invokeI64(makeI32ToI64([0x20,0x00,0xac]),[-1]),-1n)});
t('i64.extend_u_i32(-1)',()=>{assertEq(invokeI64(makeI32ToI64([0x20,0x00,0xad]),[-1]),0xFFFFFFFFn)});
t('f32.convert_s_i32(42)',()=>{assertClose(invokeF32(makeI32ToF32([0x20,0x00,0xb2]),[42]),42.0)});

testSuite('Reinterpretations');
t('i32.reinterpret_f32',()=>{assertEq(invokeI32_fromF32(makeF32ToI32([0x20,0x00,0xbc]),[-1.0]),0xBF800000|0)});
t('f32.reinterpret_i32',()=>{assertClose(invokeF32(makeI32ToF32([0x20,0x00,0xbe]),[0xBF800000]),-1.0)});

testSuite('Control Flow');
t('block constant',()=>{assertEq(invoke(makeModule([0x02,0x7f,0x41,0x01,0x0b]),[]),1)});
t('br 0 exit',()=>{assertEq(invoke(makeModule([0x41,0x01,0x02,0x40,0x0c,0x00,0x0b]),[]),1)});
t('br_if true',()=>{assertEq(invoke(makeModule([0x02,0x7f,0x41,0xe3,0x00,0x20,0x00,0x0d,0x00,0x1a,0x41,0x2a,0x0b],[0x7f]),[1]),99)});
t('br_if false',()=>{assertEq(invoke(makeModule([0x02,0x7f,0x41,0xe3,0x00,0x20,0x00,0x0d,0x00,0x1a,0x41,0x2a,0x0b],[0x7f]),[0]),42)});
t('if true:then',()=>{assertEq(invoke(makeModule([0x41,0x01,0x04,0x7f,0x41,0x0a,0x05,0x41,0x14,0x0b]),[]),10)});
t('if false:else',()=>{assertEq(invoke(makeModule([0x41,0x00,0x04,0x7f,0x41,0x0a,0x05,0x41,0x14,0x0b]),[]),20)});
t('br 1 two lvls',()=>{assertEq(invoke(makeModule([0x02,0x7f,0x02,0x40,0x41,0xe3,0x00,0x0c,0x01,0x0b,0x41,0x2a,0x0b]),[]),99)});
t('return early',()=>{assertEq(invoke(makeModule([0x41,0x01,0x0f,0x41,0x02]),[]),1)});
t('drop',()=>{assertEq(invoke(makeModule([0x41,0x01,0x41,0x02,0x1a,0x41,0x03]),[]),3)});
t('select true',()=>{assertEq(invoke(makeModule([0x41,0x2a,0x41,0x0a,0x41,0x01,0x1b]),[]),42)});
t('select false',()=>{assertEq(invoke(makeModule([0x41,0x2a,0x41,0x0a,0x41,0x00,0x1b]),[]),10)});

testSuite('Memory');
t('store verify',()=>{const rt=new WasmRuntime();const inst=rt.instantiate(makeMemModule([0x20,0x00,0x20,0x01,0x36,0x02,0x00]));rt.invokeByName(inst,'test',[WasmValue.i32(0),WasmValue.i32(42)]);assertEq(new DataView(inst.memories[0].buffer).getInt32(0,true),42)});
t('mem size',()=>{const b=[];b.push(0x00,0x61,0x73,0x6d,0x01,0x00,0x00,0x00);const tb=[0x01,0x60];pushLeb(tb,0);pushLeb(tb,1);tb.push(0x7f);b.push(0x01);pushLeb(b,tb.length);b.push(...tb);b.push(0x03,0x02,0x01,0x00);b.push(0x05,0x03,0x01,0x00,0x01);const nm=[0x04,0x74,0x65,0x73,0x74];b.push(0x07);pushLeb(b,3+nm.length);b.push(0x01,...nm,0x00,0x00);const cb=[0x00,0x3f,0x00,0x0b];const cs=[0x01];pushLeb(cs,cb.length);cs.push(...cb);b.push(0x0a);pushLeb(b,cs.length);b.push(...cs);assertEq(new WasmRuntime().invokeByName(new WasmRuntime().instantiate(new Uint8Array(b)),'test',[]).values[0].getAsI32(),1)});

testSuite('Traps');
t('unreachable',()=>{const b=[];b.push(0x00,0x61,0x73,0x6d,0x01,0x00,0x00,0x00);const tb=[0x01,0x60];pushLeb(tb,0);pushLeb(tb,1);tb.push(0x7f);b.push(0x01);pushLeb(b,tb.length);b.push(...tb);b.push(0x03,0x02,0x01,0x00);const nm=[0x04,0x74,0x65,0x73,0x74];b.push(0x07);pushLeb(b,3+nm.length);b.push(0x01,...nm,0x00,0x00);const cb=[0x00,0x00,0x0b];const cs=[0x01];pushLeb(cs,cb.length);cs.push(...cb);b.push(0x0a);pushLeb(b,cs.length);b.push(...cs);assertNotNull(new WasmRuntime().invokeByName(new WasmRuntime().instantiate(new Uint8Array(b)),'test',[]).trap)});

// ── WASI ─────────────────────────────────────────────────────────────────────
testSuite('WASI args/environ');
function makeImportModule(imports, body, resultTypes) {
  resultTypes = resultTypes || [0x7f];
  const b = [];
  b.push(0x00,0x61,0x73,0x6d,0x01,0x00,0x00,0x00);
  function makeSig(p, r) { const s = [0x60]; pushLeb(s, p.length); for (const t of p) s.push(t); pushLeb(s, r.length); for (const t of r) s.push(t); return s; }
  const typeSigs = [], impTypeIdx = [];
  for (const imp of imports) {
    const sig = makeSig(imp.params, imp.results);
    let found = -1;
    for (let i = 0; i < typeSigs.length; i++) { if (JSON.stringify(typeSigs[i]) === JSON.stringify(sig)) { found = i; break; } }
    if (found < 0) { typeSigs.push(sig); impTypeIdx.push(typeSigs.length - 1); }
    else { impTypeIdx.push(found); }
  }
  typeSigs.push(makeSig([], resultTypes));
  const localTypeIdx = typeSigs.length - 1;
  const tb = []; pushLeb(tb, typeSigs.length); for (const s of typeSigs) tb.push(...s);
  b.push(0x01); pushLeb(b, tb.length); b.push(...tb);
  if (imports.length > 0) {
    const impData = []; pushLeb(impData, imports.length);
    for (let i = 0; i < imports.length; i++) {
      pushLeb(impData, imports[i].mod.length);
      for (const c of imports[i].mod) impData.push(c.charCodeAt(0));
      pushLeb(impData, imports[i].name.length);
      for (const c of imports[i].name) impData.push(c.charCodeAt(0));
      impData.push(0x00); pushLeb(impData, impTypeIdx[i]);
    }
    b.push(0x02); pushLeb(b, impData.length); b.push(...impData);
  }
  b.push(0x03, 0x02, 0x01); pushLeb(b, localTypeIdx);
  b.push(0x05, 0x03, 0x01, 0x00, 0x01);
  const nm = [0x04,0x74,0x65,0x73,0x74];
  b.push(0x07); pushLeb(b, 3 + nm.length); b.push(0x01, ...nm, 0x00); pushLeb(b, imports.length);
  const cb = [0x00, ...body, 0x0b];
