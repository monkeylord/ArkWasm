// ── Memory Boundary ───────────────────────────────────────────────────────────
testSuite('Memory Boundary');
function memMod(body,params,results,initData,memPages){const b=[];b.push(0x00,0x61,0x73,0x6d,0x01,0x00,0x00,0x00);const tb=[0x01,0x60];pushLeb(tb,params.length);for(const p of params)tb.push(p);pushLeb(tb,results.length);for(const r of results)tb.push(r);b.push(0x01);pushLeb(b,tb.length);b.push(...tb);b.push(0x03,0x02,0x01,0x00);b.push(0x05,0x03,0x01,0x00);pushLeb(b,memPages||1);const nm=[0x04,0x74,0x65,0x73,0x74];b.push(0x07);pushLeb(b,3+nm.length);b.push(0x01,...nm,0x00,0x00);const cb=[0x00,...body,0x0b];const cs=[0x01];pushLeb(cs,cb.length);cs.push(...cb);b.push(0x0a);pushLeb(b,cs.length);b.push(...cs);if(initData&&initData.length>0){b.push(0x0b);pushLeb(b,initData.length+7);b.push(0x01,0x00,0x41,0x00,0x0b);pushLeb(b,initData.length);b.push(...initData)}return new Uint8Array(b)}
t('i32.store8 offset 4',()=>{const wasm=memMod([0x41,0x00,0x41,0x2a,0x3a,0x00,0x04,0x41,0x04,0x28,0x02,0x00],[],[0x7f],[0,0,0,0,0,0,0,0]);assertEq(invoke(wasm,[]),0x2a)});
t('i32.load OOB traps',()=>{const body=[0x41,0x80,0x80,0x04,0x28,0x02,0x00];const wasm=memMod(body,[],[0x7f],[],1);assertNotNull(new WasmRuntime().invokeByName(new WasmRuntime().instantiate(wasm),'test',[]).trap)});
