// ── Float Comparisons Boundary ────────────────────────────────────────────────
testSuite('Float Cmp Boundary');
function cmp32(op,a,b){const wasm=makeModule([0x20,0x00,0x20,0x01,op],[0x7d,0x7d],[0x7f]);const rt=new WasmRuntime();const r=rt.invokeByName(rt.instantiate(wasm),'test',[WasmValue.f32(a),WasmValue.f32(b)]);if(r.trap)throw Error('trap: '+r.trap);return r.values[0].getAsI32()}
function cmp64(op,a,b){const wasm=makeModule([0x20,0x00,0x20,0x01,op],[0x7c,0x7c],[0x7f]);const rt=new WasmRuntime();const r=rt.invokeByName(rt.instantiate(wasm),'test',[WasmValue.f64(a),WasmValue.f64(b)]);if(r.trap)throw Error('trap: '+r.trap);return r.values[0].getAsI32()}
t('f32.eq NaN≠NaN',()=>{assertEq(cmp32(0x5b,0/0,0/0),0)});
t('f32.eq +0==-0',()=>{assertEq(cmp32(0x5b,0,-0),1)});
t('f32.ne +0!=-0',()=>{assertEq(cmp32(0x5c,0,-0),0)});
t('f32.lt -0<+0',()=>{assertEq(cmp32(0x5d,-0,0),0)});
t('f32.le -0≤+0',()=>{assertEq(cmp32(0x5f,-0,0),1)});
t('f32.lt NaN<1',()=>{assertEq(cmp32(0x5d,0/0,1),0)});
t('f32.gt 1>NaN',()=>{assertEq(cmp32(0x5e,1,0/0),0)});
t('f32.le NaN≤1',()=>{assertEq(cmp32(0x5f,0/0,1),0)});
t('f32.ne NaN≠1',()=>{assertEq(cmp32(0x5c,0/0,1),1)});
t('f64.eq NaN≠NaN',()=>{assertEq(cmp64(0x61,0/0,0/0),0)});
t('f64.eq +0==-0',()=>{assertEq(cmp64(0x61,0,-0),1)});
t('f64.lt -0<+0',()=>{assertEq(cmp64(0x63,-0,0),0)});
t('f64.le -0≤+0',()=>{assertEq(cmp64(0x65,-0,0),1)});
t('f64.lt NaN<1',()=>{assertEq(cmp64(0x63,0/0,1),0)});
