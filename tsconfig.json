{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "tests/src/**/*.ts",
    "build/**/*.ts",
    "entry/src/main/ets/wasm/**/*.ets"
  ]
}
